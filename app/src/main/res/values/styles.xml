<resources>
    <style name="Widget.SmartAlarm.GhostButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">46dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">@color/line_strong</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="iconTint">@color/primary</item>
    </style>

    <style name="Widget.SmartAlarm.FilterChip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="android:textColor">@color/chip_text_tint</item>
        <item name="chipBackgroundColor">@color/chip_background_tint</item>
        <item name="chipStrokeColor">@color/chip_stroke_tint</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">18dp</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <style name="Widget.SmartAlarm.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/input_surface</item>
        <item name="boxStrokeColor">@color/text_input_stroke_tint</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
    </style>

    <style name="ThemeOverlay.SmartAlarm.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.SmartAlarm.DialogButton.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.SmartAlarm.DialogButton.Negative</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.SmartAlarm.Dialog</item>
    </style>

    <style name="ShapeAppearance.SmartAlarm.Dialog" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Widget.SmartAlarm.DialogButton.Positive" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="Widget.SmartAlarm.DialogButton.Negative" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
