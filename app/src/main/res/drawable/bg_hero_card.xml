<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="0"
                android:startColor="#122949"
                android:centerColor="#0A1524"
                android:endColor="#12131C" />
        </shape>
    </item>

    <item
        android:gravity="bottom|start"
        android:bottom="-70dp"
        android:left="-40dp">
        <shape android:shape="oval">
            <size
                android:width="220dp"
                android:height="220dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="110dp"
                android:startColor="#306BEFFF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item
        android:gravity="top|end"
        android:right="-24dp"
        android:top="-38dp">
        <shape android:shape="oval">
            <size
                android:width="180dp"
                android:height="180dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="92dp"
                android:startColor="#28FF9B3D"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="#2EFFFFFF" />
        </shape>
    </item>
</layer-list>
